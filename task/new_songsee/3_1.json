{
  "id": "new_songsee_3_1",
  "system_img": "default",
  "necessary": true,
  "instruction": "In Terminal, use songsee to generate a spectrogram for \"$HOME/Desktop/Ode to Joy.mp3\" starting at 12.5 seconds and lasting 8 seconds, then save it to \"$HOME/Desktop/songsee_slice_1.png\".",
  "config": [
    {
      "type": "cmd",
      "parameters": {
        "command": [
          "rm -f \"$HOME/Desktop/songsee_slice_1.png\"",
          "open -a 'Terminal'"
        ]
      }
    }
  ],
  "related_apps": [
    "terminal_no_reset"
  ],
  "reference_command": "songsee \"$HOME/Desktop/Ode to Joy.mp3\" --start 12.5 --duration 8 -o \"$HOME/Desktop/songsee_slice_1.png\"",
  "evaluator": {
    "func": [
      "new_songsee_check_render_matches_expected"
    ],
    "conj": "and",
    "parameters": [
      {
        "output_file": "$HOME/Desktop/songsee_slice_1.png",
        "input_audio": "$HOME/Desktop/Ode to Joy.mp3",
        "image_format": "png",
        "start_seconds": "12.5",
        "duration_seconds": "8"
      }
    ],
    "expected": [
      {
        "type": "common",
        "rules": {
          "func": "is_true",
          "parameters": []
        }
      }
    ]
  }
}